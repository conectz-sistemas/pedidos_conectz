generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(MERCHANT_ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  merchantId   String?
  merchant     Merchant? @relation(fields: [merchantId], references: [id])
}

model Merchant {
  id                   String            @id @default(cuid())
  slug                 String            @unique
  name                 String
  isOpen               Boolean           @default(true)
  phone                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  subscriptionStatus   String?
  stripeCustomerId     String?
  stripeSubId          String?
  cancellationFeeCents Int               @default(0)
  ingredients          Ingredient[]
  ingredientGroups     IngredientGroup[]
  orders               Order[]
  products             Product[]
  admins               User[]
}

model IngredientGroup {
  id                 String              @id @default(cuid())
  merchantId         String
  name               String
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  ingredients        Ingredient[]
  merchant           Merchant            @relation(fields: [merchantId], references: [id])
  productIngredients ProductIngredient[]

  @@unique([merchantId, name])
  @@index([merchantId])
}

model Ingredient {
  id                      String                         @id @default(cuid())
  merchantId              String
  name                    String
  priceCents              Int                            @default(0)
  isActive                Boolean                        @default(true)
  groupId                 String?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  group                   IngredientGroup?               @relation(fields: [groupId], references: [id])
  merchant                Merchant                       @relation(fields: [merchantId], references: [id])
  productExtras           ProductExtra[]
  productDefaults         ProductIngredient[]            @relation("DefaultIngredient")
  equivalenceAsBase       ProductIngredientEquivalence[] @relation("EquivalenceBase")
  equivalenceAsEquivalent ProductIngredientEquivalence[] @relation("EquivalenceEquivalent")

  @@unique([merchantId, name])
  @@index([merchantId])
}

model Product {
  id                 String              @id @default(cuid())
  merchantId         String
  name               String
  description        String?
  basePriceCents     Int
  isActive           Boolean             @default(true)
  imageUrl           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orderItems         OrderItem[]
  merchant           Merchant            @relation(fields: [merchantId], references: [id])
  extras             ProductExtra[]
  defaultIngredients ProductIngredient[]

  @@index([merchantId])
}

model ProductIngredient {
  id           String                         @id @default(cuid())
  productId    String
  ingredientId String
  groupId      String?
  isRemovable  Boolean                        @default(true)
  sortOrder    Int                            @default(0)
  isLocked     Boolean                        @default(false)
  group        IngredientGroup?               @relation(fields: [groupId], references: [id])
  ingredient   Ingredient                     @relation("DefaultIngredient", fields: [ingredientId], references: [id])
  product      Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  equivalences ProductIngredientEquivalence[] @relation("EquivalenceOnProductIngredient")

  @@unique([productId, ingredientId])
  @@index([productId])
}

model ProductIngredientEquivalence {
  id                     String            @id @default(cuid())
  productIngredientId    String
  baseIngredientId       String
  equivalentIngredientId String
  baseIngredient         Ingredient        @relation("EquivalenceBase", fields: [baseIngredientId], references: [id])
  equivalentIngredient   Ingredient        @relation("EquivalenceEquivalent", fields: [equivalentIngredientId], references: [id])
  productIngredient      ProductIngredient @relation("EquivalenceOnProductIngredient", fields: [productIngredientId], references: [id], onDelete: Cascade)

  @@unique([productIngredientId, equivalentIngredientId])
  @@index([productIngredientId])
}

model ProductExtra {
  id              String     @id @default(cuid())
  productId       String
  ingredientId    String
  extraPriceCents Int
  isActive        Boolean    @default(true)
  sortOrder       Int        @default(0)
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  product         Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@index([productId])
}

model Order {
  id                   String        @id @default(cuid())
  merchantId           String
  publicCode           String
  status               OrderStatus   @default(NEW)
  customerName         String
  customerWhatsApp     String
  deliveryType         String
  address              String?
  paymentMethod        PaymentMethod
  paymentTiming        PaymentTiming
  cashChangeForCents   Int?
  subtotalCents        Int
  cancellationFeeCents Int           @default(0)
  totalCents           Int
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  merchant             Merchant      @relation(fields: [merchantId], references: [id])
  items                OrderItem[]

  @@unique([merchantId, publicCode])
  @@index([merchantId, createdAt])
  @@index([merchantId, status])
}

model OrderItem {
  id             String                  @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int                     @default(1)
  basePriceCents Int
  productName    String
  notes          String?
  createdAt      DateTime                @default(now())
  order          Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product                 @relation(fields: [productId], references: [id])
  modifications  OrderItemModification[]

  @@index([orderId])
}

model OrderItemModification {
  id                   String           @id @default(cuid())
  orderItemId          String
  type                 ModificationType
  baseIngredientName   String?
  chosenIngredientName String?
  priceDeltaCents      Int              @default(0)
  orderItem            OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

enum UserRole {
  SUPERADMIN
  MERCHANT_ADMIN
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
}

enum PaymentTiming {
  ON_ORDER
  ON_PICKUP_OR_DELIVERY
}

enum ModificationType {
  REMOVE
  SUBSTITUTE
  EXTRA
}
